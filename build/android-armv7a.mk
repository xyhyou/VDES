PLATFORMDIR = android-armv7a
MAKECORE = mk_core.ndk
DEBUG=

ifdef windir
WIN32 := TRUE
else
	ifdef WINDIR
	WIN32 := TRUE
	endif
endif

ifeq ($(WIN32),TRUE)
PATH := $(MAKEROOT)cyg\\bin;$(PATH)
endif

ifndef JOBS
JOBS = 4
endif

C_PREDEF = LINUX ANDROID SPDLOG_COMPILED_LIB
ifdef DEBUG
	C_PREDEF += _DEBUG
endif

# C_PREDEF += DISABLE_CMAP
OUTPUTDIR	=	../output/$(PLATFORMDIR)
CFLAGS += -march=armv7-a -mfloat-abi=softfp -mfpu=neon
CFLAGS += -std=c++11
MAKEDIR = makefiles/
OBJROOT = obj/$(PLATFORMDIR)/

BUILDS = common platform zlib map platform navi echo alert cmcfcard tide BAM VDES

.PHONY: $(BUILDS) clean
all:  $(BUILDS)

common:
	@$(MAKE) -j$(JOBS) -f $(MAKEDIR)common.mk \
	OUTPUTFILE=libcommon.a \
	OBJROOT=$(OBJROOT) OUTPUTDIR=$(OUTPUTDIR)\
	 ADD_PREDEF="$(C_PREDEF)" ADD_CFLAGS+="$(CFLAGS)" DEBUG=$(DEBUG) RUNTIME_LIB=$(RUNTIME_LIB) MAKECORE=$(MAKECORE)

